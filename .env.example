# Discord Bot Token (from Discord Developer Portal)
DISCORD_TOKEN=your_bot_token_here

# Application ID (from Discord Developer Portal)
CLIENT_ID=your_client_id_here

# Guild ID for guild-scoped command registration (optional, leave empty for global)
GUILD_ID=your_guild_id_here

# Roles allowed to use /wipe command (comma-separated role IDs)
ALLOWED_ROLES=role_id_1,role_id_2

# Role to mention in wipe announcements (role ID)
TEAM_ROLE_ID=your_team_role_id_here

# Embed color (hex without #)
EMBED_COLOR=FF4500

# Server name shown in wipe embeds
SERVER_NAME=Rusticated EU Main

# Timezone for displaying dates (IANA timezone string)
TIMEZONE=UTC

# API server (used by the Chrome extension)
API_PORT=3000
API_KEY=change_me_to_a_secret_key

# SQLite database file path
# Locally: ./data/bot.db
# On Railway: /data/bot.db  (mount a Volume at /data in Railway dashboard)
DATABASE_PATH=./data/bot.db
