{
  "name": "rust-clan-bot",
  "version": "1.0.0",
  "description": "Production-ready Discord bot for Rust clan wipe attendance tracking",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "ts-node-dev --respawn --transpile-only src/index.ts",
    "deploy": "ts-node src/deploy-commands.ts",
    "lint": "eslint src/**/*.ts"
  },
  "dependencies": {
    "discord.js": "^14.16.3",
    "better-sqlite3": "^9.6.0",
    "dotenv": "^16.4.5",
    "winston": "^3.14.2",
    "csv-stringify": "^6.5.1"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.11",
    "@types/node": "^20.14.0",
    "typescript": "^5.5.3",
    "ts-node-dev": "^2.0.0",
    "ts-node": "^10.9.2"
  }
}
